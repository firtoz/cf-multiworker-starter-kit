{
	"name": "cf-multiworker-starter-kit",
	"private": true,
	"repository": {
		"type": "git",
		"url": "https://github.com/firtoz/cf-multiworker-starter-kit.git"
	},
	"workspaces": {
		"packages": [
			"apps/*",
			"packages/*",
			"durable-objects/*"
		],
		"catalog": {
			"@typescript/native-preview": "^7.0.0-dev.20260428.1",
			"@biomejs/biome": "^2.4.13",
			"@firtoz/socka": "^3.0.3",
			"@firtoz/hono-fetcher": "^2.7.2",
			"@types/node": "^25.6.0",
			"alchemy": "^0.93.4",
			"hono": "^4.12.15",
			"typescript": "^6.0.3",
			"zod": "^4.3.6"
		}
	},
	"scripts": {
		"agents:link": "bash agents/install-symlinks.sh",
		"setup": "bun run --cwd packages/scripts setup",
		"setup:prod": "bun run --cwd packages/scripts setup:prod",
		"github:secrets:sync": "bun --env-file .env.production alchemy deploy stacks/admin.ts --app cf-starter-admin --stage prod",
		"dev": "turbo run dev --filter=cf-starter-web --filter=cf-starter-db --filter=chatroom-do --filter=ping-do --filter=other-worker",
		"deploy": "turbo run deploy --filter=cf-starter-web",
		"destroy": "turbo run destroy",
		"build": "turbo run build:local",
		"lint": "turbo lint",
		"lint:format": "turbo lint:format",
		"typecheck": "turbo run typecheck:local",
		"typecheck:local": "turbo run typecheck:local",
		"typecheck:root": "tsgo --noEmit -p .",
		"typecheck:prod": "turbo run typecheck:prod",
		"typegen": "turbo run typegen:local",
		"typegen:local": "turbo run typegen:local",
		"typegen:prod": "turbo run typegen:prod",
		"check:drizzle-generated": "bun run --cwd packages/scripts check:drizzle-generated",
		"outdated": "bun outdated --recursive",
		"update:interactive": "bun update --latest --ir",
		"clean": "turbo clean && rm -rf node_modules **/node_modules",
		"db:generate": "turbo run db:generate --filter=cf-starter-db",
		"d1:migrate:local": "turbo run d1:migrate:local --filter=cf-starter-db",
		"d1:migrate:remote": "turbo run d1:migrate:remote --filter=cf-starter-db"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.13",
		"@cloudflare/workers-types": "^4.20260425.1",
		"@turbo/gen": "^2.9.6",
		"@types/bun": "^1.3.13",
		"@typescript/native-preview": "catalog:",
		"alchemy": "catalog:",
		"turbo": "^2.9.6",
		"typescript": "catalog:"
	},
	"packageManager": "bun@1.3.0"
}
