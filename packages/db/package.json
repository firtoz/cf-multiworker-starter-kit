{
	"name": "cf-starter-db",
	"private": true,
	"type": "module",
	"exports": {
		".": {
			"types": "./src/index.ts",
			"default": "./src/index.ts"
		},
		"./alchemy": "./alchemy.run.ts"
	},
	"scripts": {
		"db:generate": "drizzle-kit generate",
		"db:studio": "drizzle-kit studio",
		"d1:migrate:local": "node -e \"console.log('Local D1: run bun run dev — web loads cf-starter-db/alchemy and Alchemy applies packages/db/drizzle to the local D1 binding.'); process.exit(0)\"",
		"d1:migrate:remote": "bun --env-file ../../.env.production alchemy deploy --app cf-starter-db --stage prod",
		"deploy": "bun --env-file ../../.env.production alchemy deploy --app cf-starter-db --stage prod",
		"destroy": "bun --env-file ../../.env.production alchemy destroy --app cf-starter-db --stage prod",
		"dev": "bun --env-file ../../.env.local alchemy dev --app cf-starter-db --stage local",
		"typegen:local": "tsgo --noEmit -p .",
		"typegen:prod": "tsgo --noEmit -p .",
		"typecheck:local": "tsgo --noEmit -p .",
		"typecheck:prod": "tsgo --noEmit -p ."
	},
	"dependencies": {
		"drizzle-orm": "^0.45.0"
	},
	"devDependencies": {
		"@cloudflare/workers-types": "^4.20260425.1",
		"@types/node": "catalog:",
		"@typescript/native-preview": "catalog:",
		"alchemy": "catalog:",
		"cf-starter-alchemy": "workspace:*",
		"drizzle-kit": "^0.31.4",
		"typescript": "catalog:"
	}
}
