{
	"$schema": "../../node_modules/turbo/schema.json",
	"extends": ["//"],
	"tasks": {
		"dev": {
			"dependsOn": ["scripts#dev:preflight", "db:generate", "typegen:local"],
			"inputs": [
				"alchemy.run.ts",
				"src/**/*.ts",
				"drizzle/**",
				"$TURBO_ROOT$/.env.local",
				"package.json"
			],
			"persistent": true,
			"cache": false
		},
		"db:generate": {
			"inputs": ["drizzle.config.ts", "src/**/*.ts"],
			"outputs": ["drizzle/**"]
		},
		"typegen:local": {
			"dependsOn": ["db:generate"],
			"inputs": [
				"alchemy.run.ts",
				"drizzle.config.ts",
				"drizzle/**",
				"src/**/*.ts",
				"tsconfig.json",
				"package.json",
				"$TURBO_ROOT$/tsconfig.base.json"
			],
			"outputs": []
		},
		"typegen:prod": {
			"dependsOn": ["db:generate"],
			"inputs": [
				"alchemy.run.ts",
				"drizzle.config.ts",
				"drizzle/**",
				"src/**/*.ts",
				"tsconfig.json",
				"package.json",
				"$TURBO_ROOT$/tsconfig.base.json"
			],
			"outputs": []
		},
		"typecheck:local": {
			"dependsOn": ["typegen:local"],
			"inputs": [
				"alchemy.run.ts",
				"drizzle.config.ts",
				"drizzle/**",
				"src/**/*.ts",
				"tsconfig.json",
				"package.json",
				"$TURBO_ROOT$/tsconfig.base.json"
			],
			"outputs": []
		},
		"typecheck:prod": {
			"dependsOn": ["typegen:prod"],
			"inputs": [
				"alchemy.run.ts",
				"drizzle.config.ts",
				"drizzle/**",
				"src/**/*.ts",
				"tsconfig.json",
				"package.json",
				"$TURBO_ROOT$/tsconfig.base.json"
			],
			"outputs": []
		},
		"deploy": {
			"dependsOn": ["typecheck:prod", "db:generate"],
			"cache": false,
			"inputs": [
				"alchemy.run.ts",
				"drizzle.config.ts",
				"drizzle/**",
				"src/**/*.ts",
				"package.json"
			],
			"outputs": []
		},
		"destroy": {
			"cache": false,
			"outputs": []
		},
		"d1:migrate:local": {
			"inputs": ["drizzle.config.ts", "src/**/*.ts", "drizzle/**"],
			"outputs": [],
			"cache": false
		},
		"d1:migrate:remote": {
			"dependsOn": ["db:generate"],
			"inputs": ["alchemy.run.ts", "drizzle.config.ts", "src/**/*.ts", "drizzle/**"],
			"outputs": [],
			"cache": false
		}
	}
}
