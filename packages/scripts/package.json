{
	"name": "scripts",
	"private": true,
	"type": "module",
	"scripts": {
		"build": "node -e \"process.exit(0)\"",
		"build:local": "node -e \"process.exit(0)\"",
		"dev:preflight": "bun ./src/dev-preflight.ts",
		"dev:preflight:interactive": "ALCHEMY_STATE_PASSWORD_INTERACTIVE=1 bun ./src/dev-preflight.ts",
		"check:drizzle-generated": "bun ./src/check-drizzle-generated.ts",
		"setup": "bun ./src/setup-env.ts",
		"setup:local": "bun ./src/setup-env.ts --local",
		"setup:prod": "bun ./src/setup-env.ts --prod",
		"setup:staging": "bun ./src/setup-env.ts --staging",
		"quickstart": "bun ./src/quickstart.ts",
		"onboard:staging": "bun ./src/onboard-staging.ts",
		"onboard:prod": "bun ./src/onboard-prod.ts",
		"github:setup": "bun ./src/github-setup.ts",
		"github:setup:staging": "bun ./src/github-setup.ts --staging",
		"github:setup:prod": "bun ./src/github-setup.ts --prod",
		"deploy:preflight:prod": "bunx dotenv-cli -v STAGE=prod -- bun ./src/deploy-preflight.ts prod",
		"deploy:preflight:staging": "bunx dotenv-cli -v STAGE=staging -- bun ./src/deploy-preflight.ts staging",
		"deploy:preflight:preview": "bun ./src/deploy-preflight.ts preview",
		"verify:deploy-env:preview": "bun ./src/verify-deploy-env.ts",
		"lint": "biome check --write .",
		"lint:format": "biome format --write ."
	},
	"devDependencies": {
		"@biomejs/biome": "catalog:",
		"@clack/prompts": "^1.3.0"
	},
	"dependencies": {
		"alchemy-utils": "workspace:*",
		"dotenv": "catalog:"
	}
}
