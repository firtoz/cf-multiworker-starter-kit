{
	"name": "scripts",
	"private": true,
	"type": "module",
	"scripts": {
		"build": "node -e \"process.exit(0)\"",
		"build:local": "node -e \"process.exit(0)\"",
		"dev:preflight": "bun ./dev-preflight.ts",
		"dev:preflight:interactive": "ALCHEMY_STATE_PASSWORD_INTERACTIVE=1 bun ./dev-preflight.ts",
		"check:drizzle-generated": "bun ./check-drizzle-generated.ts",
		"setup": "bun ./setup-env.ts",
		"setup:local": "bun ./setup-env.ts --local",
		"setup:prod": "bun ./setup-env.ts --prod",
		"setup:staging": "bun ./setup-env.ts --staging",
		"github:setup": "bun ./github-setup.ts",
		"github:setup:staging": "bun ./github-setup.ts --staging",
		"github:setup:prod": "bun ./github-setup.ts --prod",
		"deploy:preflight:prod": "bunx dotenv-cli -v STAGE=prod -- bun ./deploy-preflight.ts prod",
		"deploy:preflight:staging": "bunx dotenv-cli -v STAGE=staging -- bun ./deploy-preflight.ts staging",
		"deploy:preflight:preview": "bun ./deploy-preflight.ts preview"
	},
	"devDependencies": {
		"@clack/prompts": "^1.3.0"
	},
	"dependencies": {
		"alchemy-utils": "workspace:*",
		"dotenv": "catalog:"
	}
}
