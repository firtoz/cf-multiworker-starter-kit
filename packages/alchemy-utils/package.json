{
	"name": "alchemy-utils",
	"private": true,
	"type": "module",
	"exports": {
		".": {
			"types": "./src/password.ts",
			"default": "./src/password.ts"
		},
		"./*": {
			"types": "./src/*.ts",
			"default": "./src/*.ts"
		}
	},
	"scripts": {
		"deploy:prod": "node -e \"process.exit(0)\"",
		"deploy:staging": "node -e \"process.exit(0)\"",
		"deploy:preview": "node -e \"process.exit(0)\"",
		"destroy:prod": "node -e \"process.exit(0)\"",
		"destroy:staging": "node -e \"process.exit(0)\"",
		"destroy:preview": "node -e \"process.exit(0)\"",
		"lint": "biome check --write .",
		"lint:format": "biome format --write .",
		"typegen:local": "tsgo --noEmit -p .",
		"typegen:prod": "tsgo --noEmit -p .",
		"typecheck:local": "tsgo --noEmit -p .",
		"typecheck:prod": "tsgo --noEmit -p ."
	},
	"devDependencies": {
		"@biomejs/biome": "catalog:",
		"@types/node": "catalog:",
		"@typescript/native-preview": "catalog:",
		"typescript": "catalog:"
	}
}
