{
	"$schema": "../../node_modules/turbo/schema.json",
	"extends": ["//"],
	"tasks": {
		"typegen": {
			"dependsOn": ["^typegen"],
			"inputs": ["src/**/*.ts", "tsconfig.json", "package.json", "$TURBO_ROOT$/tsconfig.base.json"],
			"outputs": []
		},
		"typecheck": {
			"dependsOn": ["typegen", "^typecheck"],
			"inputs": ["src/**/*.ts", "tsconfig.json", "package.json", "$TURBO_ROOT$/tsconfig.base.json"],
			"outputs": []
		},
		"deploy:prod": {
			"dependsOn": ["typecheck"],
			"cache": false,
			"outputs": []
		},
		"deploy:staging": {
			"dependsOn": ["typecheck"],
			"cache": false,
			"outputs": []
		},
		"deploy:preview": {
			"dependsOn": ["typecheck"],
			"cache": false,
			"outputs": []
		},
		"destroy:prod": {
			"cache": false,
			"outputs": []
		},
		"destroy:staging": {
			"cache": false,
			"outputs": []
		},
		"destroy:preview": {
			"cache": false,
			"outputs": []
		}
	}
}
