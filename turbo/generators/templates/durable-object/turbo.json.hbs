{
	"$schema": "../../node_modules/turbo/schema.json",
	"extends": ["//"],
	"tasks": {
		"dev": {
			"dependsOn": ["typegen:local"],
			"inputs": ["workers/**/*.ts", "src/**/*.ts", "alchemy.run.ts", "$TURBO_ROOT$/.env.local", "package.json"],
			"persistent": true,
			"cache": false
		},
		"lint": {
			"dependsOn": ["typecheck:local"],
			"inputs": ["workers/**/*.ts", "src/**/*.ts", "tsconfig.json", "tsconfig.cloudflare.json", "biome.json"],
			"outputs": []
		},
		"lint:format": {
			"inputs": ["workers/**/*.ts", "src/**/*.ts", "tsconfig.json", "tsconfig.cloudflare.json", "biome.json"],
			"outputs": []
		},
		"typecheck:local": {
			"dependsOn": ["db:generate", "typegen:local"],
			"inputs": [
				"workers/**/*.ts",
				"src/**/*.ts",
				"drizzle/**",
				"alchemy.run.ts",
				"tsconfig.json",
				"tsconfig.cloudflare.json",
				"package.json",
				"$TURBO_ROOT$/tsconfig.base.json",
				"env.d.ts"
			],
			"outputs": []
		},
		"typecheck:prod": {
			"dependsOn": ["db:generate", "typegen:prod"],
			"inputs": [
				"workers/**/*.ts",
				"src/**/*.ts",
				"drizzle/**",
				"alchemy.run.ts",
				"tsconfig.json",
				"tsconfig.cloudflare.json",
				"package.json",
				"$TURBO_ROOT$/tsconfig.base.json",
				"env.d.ts"
			],
			"outputs": []
		},
		"typegen:local": {
			"dependsOn": ["^typegen:local"],
			"inputs": [
				"workers/**/*.ts",
				"src/**/*.ts",
				"alchemy.run.ts",
				"$TURBO_ROOT$/.env.local",
				"package.json",
				"env.d.ts"
			],
			"outputs": []
		},
		"typegen:prod": {
			"dependsOn": ["^typegen:prod"],
			"inputs": [
				"workers/**/*.ts",
				"src/**/*.ts",
				"alchemy.run.ts",
				"$TURBO_ROOT$/.env.production",
				"package.json",
				"env.d.ts"
			],
			"outputs": []
		},
		"deploy:prod": {
			"dependsOn": ["db:generate", "typecheck:prod"],
			"cache": false,
			"outputs": []
		},
		"deploy:staging": {
			"dependsOn": ["db:generate", "typecheck:prod"],
			"cache": false,
			"outputs": []
		},
		"deploy:preview": {
			"dependsOn": ["db:generate", "typecheck:prod"],
			"cache": false,
			"outputs": []
		},
		"db:generate": {
			"inputs": ["drizzle.config.ts", "src/**/*.ts"],
			"outputs": ["drizzle/**"]
		},
		"destroy:prod": {
			"cache": false,
			"outputs": []
		},
		"destroy:staging": {
			"cache": false,
			"outputs": []
		},
		"destroy:preview": {
			"cache": false,
			"outputs": []
		}
	}
}
