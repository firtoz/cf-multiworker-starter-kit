{
	"name": "{{ kebabCase name }}",
	"private": true,
	"type": "module",
	"exports": {
		"./alchemy": "./alchemy.run.ts",
		"./workers/rpc": "./workers/rpc.ts"
	},
	"scripts": {
{{#if usesSqlite}}
		"db:generate": "drizzle-kit generate",
{{/if}}
		"deploy": "bun --env-file ../../.env.production alchemy deploy --app cf-starter-{{ kebabCase name }} --stage prod",
		"destroy": "bun --env-file ../../.env.production alchemy destroy --app cf-starter-{{ kebabCase name }} --stage prod",
		"dev": "bun --env-file ../../.env.local alchemy dev --app cf-starter-{{ kebabCase name }} --stage local",
		"typegen:local": "node -e \"process.exit(0)\"",
		"typegen:prod": "node -e \"process.exit(0)\"",
		"typecheck:local": "tsgo --noEmit -p ./tsconfig.json",
		"typecheck:prod": "tsgo --noEmit -p ./tsconfig.json",
		"lint": "biome check --write .",
		"lint:format": "biome format --write ."
	},
	"packageManager": "bun@1.3.0",
	"devDependencies": {
		"cf-starter-alchemy": "workspace:*",
		"@cloudflare/workers-types": "^4.20260423.1",
		"@typescript/native-preview": "catalog:",
		"@biomejs/biome": "catalog:",
		"@types/node": "catalog:",
		"alchemy": "catalog:",
{{#if usesSqlite}}
		"drizzle-kit": "^0.31.4",
{{/if}}
		"typescript": "catalog:"
	},
	"dependencies": {
		"@firtoz/hono-fetcher": "catalog:",
{{#if usesSqlite}}
		"drizzle-orm": "^0.45.2",
{{/if}}
		"hono": "catalog:"
	}
}
