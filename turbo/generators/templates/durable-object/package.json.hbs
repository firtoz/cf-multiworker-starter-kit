{
	"name": "{{ kebabCase name }}",
	"private": true,
	"type": "module",
	"alchemy": {
		"app": "{{ kebabCase name }}"
	},
	"exports": {
		"./alchemy": "./alchemy.run.ts",
		"./workers/rpc": "./workers/rpc.ts"
	},
	"scripts": {
{{#if usesSqlite}}
		"db:generate": "drizzle-kit generate",
{{/if}}
		"deploy:prod": "alchemy-cli --stage prod deploy",
		"deploy:staging": "alchemy-cli --stage staging deploy",
		"deploy:preview": "alchemy-cli --stage preview deploy",
		"destroy:prod": "alchemy-cli --stage prod destroy",
		"destroy:staging": "alchemy-cli --stage staging destroy",
		"destroy:preview": "alchemy-cli --stage preview destroy",
		"dev": "alchemy-cli --stage local dev",
		"typegen": "node -e \"process.exit(0)\"",
		"typecheck": "tsgo --noEmit -p ./tsconfig.json",
		"lint": "biome check --write .",
		"lint:format": "biome format --write ."
	},
	"packageManager": "bun@1.3.13",
	"devDependencies": {
		"alchemy-utils": "workspace:*",
		"state-hub": "workspace:*",
		"@cloudflare/workers-types": "catalog:",
		"@typescript/native-preview": "catalog:",
		"@biomejs/biome": "catalog:",
		"@types/node": "catalog:",
		"alchemy": "catalog:",
{{#if usesSqlite}}
		"drizzle-kit": "catalog:",
{{/if}}
		"typescript": "catalog:"
	},
	"dependencies": {
		"@firtoz/hono-fetcher": "catalog:",
{{#if usesSqlite}}
		"drizzle-orm": "catalog:",
{{/if}}
		"hono": "catalog:"
	}
}
