{
	"name": "{{ kebabCase name }}",
	"private": true,
	"type": "module",
	"exports": {
		"./alchemy": "./alchemy.run.ts",
		"./workers/rpc": "./workers/rpc.ts"
	},
	"scripts": {
{{#if usesSqlite}}
		"db:generate": "drizzle-kit generate",
{{/if}}
		"deploy:prod": "bunx dotenv-cli -v STAGE=prod -e ../../.env.production -- bun ../../packages/alchemy-utils/src/alchemy-cli.ts deploy {{ kebabCase name }}",
		"deploy:staging": "bunx dotenv-cli -v STAGE=staging -e ../../.env.staging -- bun ../../packages/alchemy-utils/src/alchemy-cli.ts deploy {{ kebabCase name }}",
		"deploy:preview": "bunx dotenv-cli -e ../../.env.staging -- bun ../../packages/alchemy-utils/src/alchemy-cli.ts deploy {{ kebabCase name }}",
		"destroy:prod": "bunx dotenv-cli -v STAGE=prod -e ../../.env.production -- bun ../../packages/alchemy-utils/src/alchemy-cli.ts destroy {{ kebabCase name }}",
		"destroy:staging": "bunx dotenv-cli -v STAGE=staging -e ../../.env.staging -- bun ../../packages/alchemy-utils/src/alchemy-cli.ts destroy {{ kebabCase name }}",
		"destroy:preview": "bunx dotenv-cli -e ../../.env.staging -- bun ../../packages/alchemy-utils/src/alchemy-cli.ts destroy {{ kebabCase name }}",
		"dev": "bunx dotenv-cli -v STAGE=local -e ../../.env.local -- bun ../../packages/alchemy-utils/src/alchemy-cli.ts dev {{ kebabCase name }}",
		"typegen:local": "node -e \"process.exit(0)\"",
		"typegen:prod": "node -e \"process.exit(0)\"",
		"typecheck:local": "tsgo --noEmit -p ./tsconfig.json",
		"typecheck:prod": "tsgo --noEmit -p ./tsconfig.json",
		"lint": "biome check --write .",
		"lint:format": "biome format --write ."
	},
	"packageManager": "bun@1.3.0",
	"devDependencies": {
		"alchemy-utils": "workspace:*",
		"state-hub": "workspace:*",
		"@cloudflare/workers-types": "catalog:",
		"@typescript/native-preview": "catalog:",
		"@biomejs/biome": "catalog:",
		"@types/node": "catalog:",
		"alchemy": "catalog:",
{{#if usesSqlite}}
		"drizzle-kit": "catalog:",
{{/if}}
		"typescript": "catalog:"
	},
	"dependencies": {
		"@firtoz/hono-fetcher": "catalog:",
{{#if usesSqlite}}
		"drizzle-orm": "catalog:",
{{/if}}
		"hono": "catalog:"
	}
}
