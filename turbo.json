{
	"$schema": "./node_modules/turbo/schema.json",
	"globalDependencies": [
		".env.local",
		".env.production",
		".env.staging",
		"tsconfig.base.json",
		"packages/alchemy-utils/src/password.ts",
		"packages/alchemy-utils/src/env-requirements.ts",
		"packages/alchemy-utils/src/worker-peer-scripts.ts",
		"packages/alchemy-utils/src/deployment-stage.ts",
		"packages/alchemy-utils/src/alchemy-cli.ts",
		"packages/scripts/src/collected-env-requirements.ts",
		"packages/state-hub/alchemy.run.ts"
	],

	"ui": "tui",
	"tasks": {
		"build": {
			"outputLogs": "new-only"
		},
		"build:local": {
			"outputLogs": "new-only"
		},
		"build:staging": {
			"outputLogs": "new-only"
		},
		"typecheck": {
			"outputLogs": "new-only"
		},
		"typecheck:local": {
			"outputLogs": "new-only"
		},
		"typecheck:staging": {
			"outputLogs": "new-only"
		},
		"typegen": {
			"outputLogs": "new-only"
		},
		"typegen:local": {
			"outputLogs": "new-only"
		},
		"typegen:staging": {
			"outputLogs": "new-only"
		},
		"rr-typegen": {
			"outputLogs": "new-only"
		},
		"dev:preflight": {
			"cache": false,
			"outputLogs": "full"
		},
		"dev": {
			"cache": false,
			"persistent": true,
			"outputLogs": "new-only"
		},
		"deploy:prod": {
			"cache": false,
			"outputLogs": "new-only"
		},
		"deploy:staging": {
			"cache": false,
			"outputLogs": "new-only"
		},
		"deploy:preview": {
			"cache": false,
			"outputLogs": "new-only"
		},
		"destroy:prod": {
			"cache": false,
			"outputLogs": "new-only"
		},
		"destroy:staging": {
			"cache": false,
			"outputLogs": "new-only"
		},
		"destroy:preview": {
			"cache": false,
			"outputLogs": "new-only"
		},
		"chatroom-do#destroy:prod": {
			"dependsOn": ["@internal/web#destroy:prod"],
			"cache": false,
			"outputLogs": "new-only"
		},
		"ping-do#destroy:prod": {
			"dependsOn": ["@internal/web#destroy:prod"],
			"cache": false,
			"outputLogs": "new-only"
		},
		"other-worker#destroy:prod": {
			"dependsOn": ["@internal/web#destroy:prod"],
			"cache": false,
			"outputLogs": "new-only"
		},
		"@internal/db#destroy:prod": {
			"dependsOn": ["@internal/web#destroy:prod"],
			"cache": false,
			"outputLogs": "new-only"
		},
		"state-hub#destroy:prod": {
			"dependsOn": ["@internal/web#destroy:prod"],
			"cache": false,
			"outputLogs": "new-only"
		},
		"chatroom-do#destroy:staging": {
			"dependsOn": ["@internal/web#destroy:staging"],
			"cache": false,
			"outputLogs": "new-only"
		},
		"ping-do#destroy:staging": {
			"dependsOn": ["@internal/web#destroy:staging"],
			"cache": false,
			"outputLogs": "new-only"
		},
		"other-worker#destroy:staging": {
			"dependsOn": ["@internal/web#destroy:staging"],
			"cache": false,
			"outputLogs": "new-only"
		},
		"@internal/db#destroy:staging": {
			"dependsOn": ["@internal/web#destroy:staging"],
			"cache": false,
			"outputLogs": "new-only"
		},
		"state-hub#destroy:staging": {
			"dependsOn": ["@internal/web#destroy:staging"],
			"cache": false,
			"outputLogs": "new-only"
		},
		"chatroom-do#destroy:preview": {
			"dependsOn": ["@internal/web#destroy:preview"],
			"cache": false,
			"outputLogs": "new-only"
		},
		"ping-do#destroy:preview": {
			"dependsOn": ["@internal/web#destroy:preview"],
			"cache": false,
			"outputLogs": "new-only"
		},
		"other-worker#destroy:preview": {
			"dependsOn": ["@internal/web#destroy:preview"],
			"cache": false,
			"outputLogs": "new-only"
		},
		"@internal/db#destroy:preview": {
			"dependsOn": ["@internal/web#destroy:preview"],
			"cache": false,
			"outputLogs": "new-only"
		},
		"state-hub#destroy:preview": {
			"dependsOn": ["@internal/web#destroy:preview"],
			"cache": false,
			"outputLogs": "new-only"
		},
		"lint": {
			"outputLogs": "new-only"
		},
		"lint:format": {
			"outputLogs": "new-only"
		},
		"clean": {
			"cache": false
		},
		"db:generate": {
			"outputLogs": "new-only"
		}
	},
	"globalEnv": [
		"CLOUDFLARE_API_TOKEN",
		"CLOUDFLARE_ACCOUNT_ID",
		"CI",
		"ALCHEMY_PASSWORD",
		"ALCHEMY_STATE_TOKEN",
		"CHATROOM_INTERNAL_SECRET",
		"STAGE",
		"MULTIWORKER_DEPLOY_ENABLED",
		"TURBO_TELEMETRY_DISABLED"
	]
}
