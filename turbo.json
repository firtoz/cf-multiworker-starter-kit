{
	"$schema": "./node_modules/turbo/schema.json",
	"globalDependencies": [".env.local", ".env.production", ".env.staging", "tsconfig.base.json", "packages/cf-starter-alchemy/password.ts", "packages/cf-starter-alchemy/worker-peer-scripts.ts", "packages/cf-starter-alchemy/deployment-stage.ts"],

	"ui": "tui",
	"tasks": {
		"build": {
			"outputLogs": "new-only"
		},
		"build:local": {
			"outputLogs": "new-only"
		},
		"build:staging": {
			"outputLogs": "new-only"
		},
		"typecheck": {
			"outputLogs": "new-only"
		},
		"typecheck:local": {
			"outputLogs": "new-only"
		},
		"typecheck:staging": {
			"outputLogs": "new-only"
		},
		"typegen": {
			"outputLogs": "new-only"
		},
		"typegen:local": {
			"outputLogs": "new-only"
		},
		"typegen:staging": {
			"outputLogs": "new-only"
		},
		"rr-typegen": {
			"outputLogs": "new-only"
		},
		"dev:preflight": {
			"cache": false,
			"outputLogs": "full"
		},
		"dev": {
			"cache": false,
			"persistent": true,
			"outputLogs": "new-only"
		},
		"deploy:prod": {
			"cache": false,
			"outputLogs": "new-only"
		},
		"deploy:staging": {
			"cache": false,
			"outputLogs": "new-only"
		},
		"deploy:preview": {
			"cache": false,
			"outputLogs": "new-only"
		},
		"destroy:prod": {
			"cache": false,
			"outputLogs": "new-only"
		},
		"destroy:staging": {
			"cache": false,
			"outputLogs": "new-only"
		},
		"destroy:preview": {
			"cache": false,
			"outputLogs": "new-only"
		},
		"chatroom-do#destroy:prod": {
			"dependsOn": ["cf-starter-web#destroy:prod"],
			"cache": false,
			"outputLogs": "new-only"
		},
		"ping-do#destroy:prod": {
			"dependsOn": ["cf-starter-web#destroy:prod"],
			"cache": false,
			"outputLogs": "new-only"
		},
		"other-worker#destroy:prod": {
			"dependsOn": ["cf-starter-web#destroy:prod"],
			"cache": false,
			"outputLogs": "new-only"
		},
		"cf-starter-db#destroy:prod": {
			"dependsOn": ["cf-starter-web#destroy:prod"],
			"cache": false,
			"outputLogs": "new-only"
		},
		"chatroom-do#destroy:staging": {
			"dependsOn": ["cf-starter-web#destroy:staging"],
			"cache": false,
			"outputLogs": "new-only"
		},
		"ping-do#destroy:staging": {
			"dependsOn": ["cf-starter-web#destroy:staging"],
			"cache": false,
			"outputLogs": "new-only"
		},
		"other-worker#destroy:staging": {
			"dependsOn": ["cf-starter-web#destroy:staging"],
			"cache": false,
			"outputLogs": "new-only"
		},
		"cf-starter-db#destroy:staging": {
			"dependsOn": ["cf-starter-web#destroy:staging"],
			"cache": false,
			"outputLogs": "new-only"
		},
		"chatroom-do#destroy:preview": {
			"dependsOn": ["cf-starter-web#destroy:preview"],
			"cache": false,
			"outputLogs": "new-only"
		},
		"ping-do#destroy:preview": {
			"dependsOn": ["cf-starter-web#destroy:preview"],
			"cache": false,
			"outputLogs": "new-only"
		},
		"other-worker#destroy:preview": {
			"dependsOn": ["cf-starter-web#destroy:preview"],
			"cache": false,
			"outputLogs": "new-only"
		},
		"cf-starter-db#destroy:preview": {
			"dependsOn": ["cf-starter-web#destroy:preview"],
			"cache": false,
			"outputLogs": "new-only"
		},
		"lint": {
			"outputLogs": "new-only"
		},
		"lint:format": {
			"outputLogs": "new-only"
		},
		"clean": {
			"cache": false
		},
		"db:generate": {
			"outputLogs": "new-only"
		},
		"db:check-generated": {
			"outputLogs": "new-only"
		},
		"d1:migrate:local": {
			"outputLogs": "new-only"
		},
		"d1:migrate:remote": {
			"outputLogs": "new-only"
		}
	},
	"globalEnv": [
		"CLOUDFLARE_API_TOKEN",
		"CLOUDFLARE_ACCOUNT_ID",
		"CI",
		"ALCHEMY_PASSWORD",
		"CHATROOM_INTERNAL_SECRET",
		"STAGE",
		"CF_STARTER_DEPLOY_ENABLED"
	]
}
