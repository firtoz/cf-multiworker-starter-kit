{
	"name": "cf-starter-web",
	"private": true,
	"type": "module",
	"exports": {
		"./alchemy": "./alchemy.run.ts"
	},
	"scripts": {
		"build:local": "bun --env-file ../../.env.local react-router build --mode production",
		"build:prod": "bun --env-file ../../.env.production react-router build --mode production",
		"build:staging": "bun --env-file ../../.env.staging react-router build --mode production",
		"build:dev": "react-router build --mode development",
		"typegen:local": "bun run rr-typegen",
		"typegen:prod": "bun run rr-typegen",
		"typegen:staging": "bun run rr-typegen",
		"rr-typegen": "react-router typegen",
		"deploy:prod": "bunx dotenv-cli -v STAGE=prod -e ../../.env.production -- bun alchemy deploy --app cf-starter-frontend",
		"deploy:staging": "bunx dotenv-cli -v STAGE=staging -e ../../.env.staging -- bun alchemy deploy --app cf-starter-frontend",
		"deploy:preview": "bunx dotenv-cli -e ../../.env.staging -- bun alchemy deploy --app cf-starter-frontend",
		"destroy:prod": "bunx dotenv-cli -v STAGE=prod -e ../../.env.production -- bun alchemy destroy --app cf-starter-frontend",
		"destroy:staging": "bunx dotenv-cli -v STAGE=staging -e ../../.env.staging -- bun alchemy destroy --app cf-starter-frontend",
		"destroy:preview": "bunx dotenv-cli -e ../../.env.staging -- bun alchemy destroy --app cf-starter-frontend",
		"dev": "bunx dotenv-cli -v STAGE=local -e ../../.env.local -- bun alchemy dev --app cf-starter-frontend",
		"preview": "bun run build:local && vite preview",
		"typecheck:local": "concurrently -n cloudflare,node -c auto --success all \"tsgo --noEmit -p ./tsconfig.cloudflare.json\" \"tsgo --noEmit -p ./tsconfig.node.json\"",
		"typecheck:prod": "concurrently -n cloudflare,node -c auto --success all \"tsgo --noEmit -p ./tsconfig.cloudflare.json\" \"tsgo --noEmit -p ./tsconfig.node.json\"",
		"typecheck:staging": "concurrently -n cloudflare,node -c auto --success all \"tsgo --noEmit -p ./tsconfig.cloudflare.json\" \"tsgo --noEmit -p ./tsconfig.node.json\"",
		"lint": "biome check --write .",
		"lint:format": "biome format --write ."
	},
	"dependencies": {
		"@firtoz/hono-fetcher": "catalog:",
		"@firtoz/maybe-error": "^1.6.1",
		"@firtoz/router-toolkit": "^9.0.1",
		"@firtoz/socka": "catalog:",
		"cf-starter-alchemy": "workspace:*",
		"cf-starter-chat-contract": "workspace:*",
		"cf-starter-db": "workspace:*",
		"clsx": "^2.1.1",
		"chatroom-do": "workspace:*",
		"ping-do": "workspace:*",
		"isbot": "^5.1.39",
		"react": "^19.2.5",
		"react-dom": "^19.2.5",
		"react-router": "^7.14.2",
		"tailwind-merge": "^3.5.0"
	},
	"devDependencies": {
		"@biomejs/biome": "catalog:",
		"@cloudflare/vite-plugin": "^1.34.0",
		"@cloudflare/workers-types": "^4.20260425.1",
		"@react-router/dev": "^7.14.2",
		"@tailwindcss/vite": "^4.2.4",
		"@types/node": "catalog:",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@typescript/native-preview": "catalog:",
		"alchemy": "^0.93.4",
		"concurrently": "^9.1.0",
		"other-worker": "workspace:*",
		"rollup-plugin-visualizer": "^7.0.1",
		"tailwindcss": "^4.2.4",
		"typescript": "catalog:",
		"vite": "^8.0.10",
		"vite-imagetools": "^10.0.0",
		"vite-plugin-devtools-json": "^1.0.0"
	},
	"packageManager": "bun@1.3.0"
}
