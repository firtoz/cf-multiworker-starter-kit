{
	"$schema": "../../node_modules/turbo/schema.json",
	"extends": ["//"],
	"tasks": {
		"dev": {
			"dependsOn": ["scripts#dev:preflight", "typegen:local"],
			"inputs": ["workers/**/*.ts", "$TURBO_ROOT$/.env.local", "package.json"],
			"persistent": true,
			"cache": false
		},
		"lint": {
			"dependsOn": ["typecheck:local"],
			"inputs": ["workers/**/*.ts", "tsconfig.json", "biome.json"],
			"outputs": []
		},
		"lint:format": {
			"inputs": ["workers/**/*.ts", "tsconfig.json", "biome.json"],
			"outputs": []
		},
		"typecheck:local": {
			"dependsOn": ["typegen:local"],
			"inputs": [
				"alchemy.run.ts",
				"workers/**/*.ts",
				"tsconfig.json",
				"package.json",
				"$TURBO_ROOT$/tsconfig.base.json",
				"env.d.ts"
			],
			"outputs": []
		},
		"typecheck:prod": {
			"dependsOn": ["typegen:prod"],
			"inputs": [
				"alchemy.run.ts",
				"workers/**/*.ts",
				"tsconfig.json",
				"package.json",
				"$TURBO_ROOT$/tsconfig.base.json",
				"env.d.ts"
			],
			"outputs": []
		},
		"typegen:local": {
			"dependsOn": ["^typegen:local"],
			"inputs": ["workers/**/*.ts", "$TURBO_ROOT$/.env.local", "package.json", "env.d.ts"],
			"outputs": []
		},
		"typegen:prod": {
			"dependsOn": ["^typegen:prod"],
			"inputs": ["workers/**/*.ts", "$TURBO_ROOT$/.env.production", "package.json", "env.d.ts"],
			"outputs": []
		},
		"deploy:prod": {
			"dependsOn": ["typecheck:prod", "ping-do#typecheck:prod"],
			"cache": false,
			"inputs": ["alchemy.run.ts", "workers/**/*.ts", "package.json", "tsconfig.json", "env.d.ts"],
			"outputs": []
		},
		"deploy:staging": {
			"dependsOn": ["typecheck:prod", "ping-do#typecheck:prod"],
			"cache": false,
			"inputs": ["alchemy.run.ts", "workers/**/*.ts", "package.json", "tsconfig.json", "env.d.ts"],
			"outputs": []
		},
		"deploy:preview": {
			"dependsOn": ["typecheck:prod", "ping-do#typecheck:prod"],
			"cache": false,
			"inputs": ["alchemy.run.ts", "workers/**/*.ts", "package.json", "tsconfig.json", "env.d.ts"],
			"outputs": []
		},
		"destroy:prod": {
			"cache": false,
			"outputs": []
		},
		"destroy:staging": {
			"cache": false,
			"outputs": []
		},
		"destroy:preview": {
			"cache": false,
			"outputs": []
		}
	}
}
