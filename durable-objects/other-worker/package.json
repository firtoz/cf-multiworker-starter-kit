{
	"name": "other-worker",
	"private": true,
	"type": "module",
	"exports": {
		"./alchemy": "./alchemy.run.ts",
		"./workers/rpc": "./workers/rpc.ts"
	},
	"scripts": {
		"deploy": "bun --env-file ../../.env.production alchemy deploy --app other-worker --stage prod",
		"destroy": "bun --env-file ../../.env.production alchemy destroy --app other-worker --stage prod",
		"dev": "bun --env-file ../../.env.local alchemy dev --app other-worker --stage local",
		"typegen:local": "node -e \"process.exit(0)\"",
		"typegen:prod": "node -e \"process.exit(0)\"",
		"typecheck:local": "tsgo --noEmit -p ./tsconfig.json",
		"typecheck:prod": "tsgo --noEmit -p ./tsconfig.json",
		"lint": "biome check --write .",
		"lint:format": "biome format --write ."
	},
	"packageManager": "bun@1.3.0",
	"dependencies": {
		"hono": "catalog:"
	},
	"devDependencies": {
		"cf-starter-alchemy": "workspace:*",
		"@cloudflare/workers-types": "^4.20260425.1",
		"@typescript/native-preview": "catalog:",
		"@biomejs/biome": "catalog:",
		"@types/node": "catalog:",
		"alchemy": "catalog:",
		"typescript": "catalog:"
	}
}
