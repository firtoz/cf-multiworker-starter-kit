{
	"name": "ping-do",
	"private": true,
	"type": "module",
	"exports": {
		"./alchemy": "./alchemy.run.ts",
		"./workers/ping-do": "./workers/ping-do.ts",
		"./workers/rpc": "./workers/rpc.ts"
	},
	"scripts": {
		"deploy": "bun --env-file ../../.env.production alchemy deploy --app cf-starter-ping --stage prod",
		"destroy": "bun --env-file ../../.env.production alchemy destroy --app cf-starter-ping --stage prod",
		"dev": "bun --env-file ../../.env.local alchemy dev --app cf-starter-ping --stage local",
		"typegen:local": "node -e \"process.exit(0)\"",
		"typegen:prod": "node -e \"process.exit(0)\"",
		"typecheck:local": "tsgo --noEmit -p ./tsconfig.json",
		"typecheck:prod": "tsgo --noEmit -p ./tsconfig.json",
		"lint": "biome check --write .",
		"lint:format": "biome format --write ."
	},
	"packageManager": "bun@1.3.0",
	"dependencies": {
		"hono": "catalog:",
		"other-worker": "workspace:*"
	},
	"devDependencies": {
		"cf-starter-alchemy": "workspace:*",
		"@cloudflare/workers-types": "^4.20260425.1",
		"@typescript/native-preview": "catalog:",
		"@biomejs/biome": "catalog:",
		"@types/node": "catalog:",
		"alchemy": "catalog:",
		"typescript": "catalog:"
	}
}
