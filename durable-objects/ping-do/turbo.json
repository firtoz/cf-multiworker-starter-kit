{
	"$schema": "../../node_modules/turbo/schema.json",
	"extends": ["//"],
	"tasks": {
		"dev": {
			"dependsOn": ["scripts#dev:preflight", "typegen"],
			"inputs": ["workers/**/*.ts", "$TURBO_ROOT$/.env.local", "package.json"],
			"persistent": true,
			"cache": false
		},
		"lint": {
			"dependsOn": ["typecheck"],
			"inputs": ["workers/**/*.ts", "tsconfig.json", "biome.json"],
			"outputs": []
		},
		"lint:format": {
			"inputs": ["workers/**/*.ts", "tsconfig.json", "biome.json"],
			"outputs": []
		},
		"typecheck": {
			"dependsOn": ["typegen", "^typecheck"],
			"inputs": [
				"alchemy.run.ts",
				"workers/**/*.ts",
				"tsconfig.json",
				"package.json",
				"$TURBO_ROOT$/tsconfig.base.json",
				"env.d.ts"
			],
			"outputs": []
		},
		"typegen": {
			"dependsOn": ["^typegen"],
			"inputs": ["workers/**/*.ts", "package.json", "env.d.ts"],
			"outputs": []
		},
		"deploy:prod": {
			"dependsOn": ["^deploy:prod", "typecheck", "other-worker#typecheck"],
			"cache": false,
			"inputs": ["alchemy.run.ts", "workers/**/*.ts", "package.json", "tsconfig.json", "env.d.ts"],
			"outputs": []
		},
		"deploy:staging": {
			"dependsOn": ["^deploy:staging", "typecheck", "other-worker#typecheck"],
			"cache": false,
			"inputs": ["alchemy.run.ts", "workers/**/*.ts", "package.json", "tsconfig.json", "env.d.ts"],
			"outputs": []
		},
		"deploy:preview": {
			"dependsOn": ["^deploy:preview", "typecheck", "other-worker#typecheck"],
			"cache": false,
			"inputs": ["alchemy.run.ts", "workers/**/*.ts", "package.json", "tsconfig.json", "env.d.ts"],
			"outputs": []
		},
		"destroy:prod": {
			"cache": false,
			"outputs": []
		},
		"destroy:staging": {
			"cache": false,
			"outputs": []
		},
		"destroy:preview": {
			"cache": false,
			"outputs": []
		}
	}
}
