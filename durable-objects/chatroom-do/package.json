{
	"name": "chatroom-do",
	"private": true,
	"type": "module",
	"exports": {
		"./alchemy": "./alchemy.run.ts"
	},
	"scripts": {
		"db:generate": "drizzle-kit generate",
		"deploy": "bun --env-file ../../.env.production alchemy deploy --app chatroom-do --stage prod",
		"destroy": "bun --env-file ../../.env.production alchemy destroy --app chatroom-do --stage prod",
		"dev": "bun --env-file ../../.env.local alchemy dev --app chatroom-do --stage local",
		"typegen:local": "node -e \"process.exit(0)\"",
		"typegen:prod": "node -e \"process.exit(0)\"",
		"typecheck:local": "tsgo --noEmit -p ./tsconfig.json",
		"typecheck:prod": "tsgo --noEmit -p ./tsconfig.json",
		"lint": "biome check --write .",
		"lint:format": "biome format --write ."
	},
	"packageManager": "bun@1.3.0",
	"dependencies": {
		"@firtoz/socka": "catalog:",
		"@firtoz/websocket-do": "^13.0.2",
		"cf-starter-chat-contract": "workspace:*",
		"drizzle-orm": "^0.45.2",
		"hono": "catalog:"
	},
	"devDependencies": {
		"cf-starter-alchemy": "workspace:*",
		"@cloudflare/workers-types": "^4.20260425.1",
		"@typescript/native-preview": "catalog:",
		"@biomejs/biome": "catalog:",
		"@types/node": "catalog:",
		"alchemy": "catalog:",
		"drizzle-kit": "^0.31.4",
		"typescript": "catalog:"
	}
}
